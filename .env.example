# Copy this file and fill in real values locally, e.g.:
#   cp .env.example .env.api-server   (for the API server)
#   cp .env.example artifacts/woundence/.env.local   (for the web app — only VITE_ vars are used)
#   cp .env.example artifacts/woundence-mobile/.env.local   (for the mobile app — only EXPO_PUBLIC_ vars are used)
# Never commit a file with real values — .env* is gitignored except this template.
# See README.md for which service uses which variable and where to get it.

# --- Database (Supabase Postgres, via the connection pooler) ---
DATABASE_URL=

# --- Clerk auth ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PROXY_URL=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- AI wound analysis (Claude, vision) ---
ANTHROPIC_API_KEY=

# --- Supabase Storage (wound photos + documents) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Booking integration ---
# Leave blank to disable the public /api/public/book-appointment endpoint.
BOOKING_API_KEY=

# --- CORS ---
# Comma-separated list of browser origins allowed to call the API with
# credentials. Defaults to local dev origins (localhost:22916, localhost:19006)
# when unset. Add your deployed web app's origin once it's hosted, e.g.:
#   ALLOWED_ORIGINS=https://app.woundence.com,http://localhost:22916
ALLOWED_ORIGINS=

# --- Mobile app API target ---
# Domain (no protocol) the Expo app calls. Point at your Mac's LAN IP + port
# for local dev, or the hosted Railway domain to skip running a local server.
EXPO_PUBLIC_DOMAIN=
# Only needed for local dev against an HTTP-only api-server; hosted targets
# (Railway, etc.) use HTTPS by default and don't need this set.
EXPO_PUBLIC_API_PROTOCOL=

# --- Service runtime config (set per-service when running locally) ---
# PORT=8080                                    # api-server
# PORT=22916                                   # woundence (web)
# BASE_PATH=/                                  # woundence (web)
# API_PROXY_TARGET=http://localhost:8080       # woundence (web) — where the dev proxy forwards /api
